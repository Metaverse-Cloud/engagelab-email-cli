{
  "name": "engagelab-email-cli",
  "version": "1.0.1",
  "description": "CLI for EngageLab Email Agent and Skill workflows",
  "type": "module",
  "main": "./dist/index.cjs",
  "exports": {
    ".": "./dist/index.cjs"
  },
  "bin": {
    "engagelab-email-cli": "./dist/index.cjs"
  },
  "files": [
    "dist/"
  ],
  "scripts": {
    "build": "node scripts/build.js",
    "cli": "node src/cli.js",
    "test": "node --test --test-reporter=spec tests",
    "prepare-package": "node scripts/prepare-package.js",
    "packcheck": "npm test && npm run prepare-package && npm pack --dry-run .npm-package",
    "publish:npm": "npm test && npm run prepare-package && npm publish .npm-package --access public"
  },
  "dependencies": {
    "cli-table3": "^0.6.5",
    "commander": "^12.1.0",
    "ky": "^2.0.2",
    "picocolors": "^1.1.1"
  },
  "keywords": [
    "engagelab",
    "email",
    "cli",
    "agent",
    "inbox"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Metaverse-Cloud/engagelab-email-cli.git"
  },
  "bugs": {
    "url": "https://github.com/Metaverse-Cloud/engagelab-email-cli/issues"
  },
  "homepage": "https://github.com/Metaverse-Cloud/engagelab-email-cli#readme",
  "license": "UNLICENSED",
  "publishConfig": {
    "access": "public"
  },
  "packageManager": "pnpm@10.24.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "esbuild": "^0.28.1"
  }
}
